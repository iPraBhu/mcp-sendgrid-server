# =============================================================================
# SendGrid MCP Server — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# --- Required ---
# Your SendGrid API key. Must have at minimum Mail Send permissions.
# For full functionality (activity, stats, suppressions), use a full-access key.
SENDGRID_API_KEY=SG.your-api-key-here

# --- Region / Endpoint ---
# Region: "global" (default) or "eu" for EU data residency
SENDGRID_REGION=global
# Override the base URL entirely (overrides SENDGRID_REGION if set)
# SENDGRID_BASE_URL=https://api.sendgrid.com

# --- Server Mode ---
# "full" (default) — all tools enabled
# "analytics" — only stats, email activity, and suppression reads; implies read-only
SENDGRID_MODE=full

# --- Safety Modes ---
# Default-safe: set to "true" to disable all write operations (validation and reads still work)
SENDGRID_READ_ONLY=true
# Extra safety switch: even with SENDGRID_READ_ONLY=false, writes remain blocked unless enabled
SENDGRID_WRITES_ENABLED=false
# Required when SENDGRID_WRITES_ENABLED=true. Must be provided as approval_token in each send/test-send call.
# SENDGRID_WRITE_APPROVAL_TOKEN=replace-with-strong-random-token
# Set to "true" to restrict sends to allowlisted recipients only
SENDGRID_TEST_MODE_ONLY=false

# --- Allowlists (comma-separated, applied when TEST_MODE_ONLY=true or for validation) ---
# Domains allowed as the sender "from" address
SENDGRID_ALLOWED_FROM_DOMAINS=yourdomain.com,anotherdomain.com
# Domains allowed as recipients (for test-send mode)
SENDGRID_ALLOWED_TO_DOMAINS=yourteam.com
# Specific recipient emails allowed in test-send mode
SENDGRID_ALLOWED_TO_EMAILS=you@yourteam.com,qa@yourteam.com

# --- Pagination ---
SENDGRID_DEFAULT_PAGE_SIZE=25
SENDGRID_MAX_PAGE_SIZE=100

# --- HTTP / Timeouts ---
SENDGRID_TIMEOUT_MS=30000

# --- MCP Transport ---
# "stdio" (default, for CLI/IDE agents) or "http" (for network-accessible MCP)
MCP_TRANSPORT=stdio
# Port used when MCP_TRANSPORT=http
MCP_HTTP_PORT=3100

# --- Logging ---
# One of: debug | info | warn | error
LOG_LEVEL=info
# Set to "true" to redact email addresses and PII in logs (recommended for production)
REDACT_PII=true
